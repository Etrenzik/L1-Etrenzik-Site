{
  "name": "ETRENZIK-CASE",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "npm run generate --workspace=@etrenzik-case/db",
    "db:push": "npm run push --workspace=@etrenzik-case/db",
    "db:migrate": "npm run migrate --workspace=@etrenzik-case/db",
    "db:seed": "npm run seed --workspace=@etrenzik-case/db",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
